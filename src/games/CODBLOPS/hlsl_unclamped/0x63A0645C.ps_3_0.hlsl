    r0.z = rsqrt(r0.z);
    oC0.w = saturate((r0.w) * (r1.w));
    oC0.x = 1.0f / (r0.x);
    oC0.y = 1.0f / (r0.y);
    oC0.z = 1.0f / (r0.z);

    return oC0;
}
